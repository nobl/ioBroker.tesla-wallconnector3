{
  "name": "iobroker.tesla-wallconnector3",
  "version": "1.0.6",
  "description": "This adapter reads API information from a Tesla Wall Connector Gen 3",
  "author": {
    "name": "NoBl",
    "email": "github@bluemle.org"
  },
  "homepage": "https://github.com/nobl/ioBroker.tesla-wallconnector3",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "tesla",
    "vehicle",
    "energy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nobl/ioBroker.tesla-wallconnector3.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^4.3.4",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^4.4.1",
    "chai-as-promised": "^8.0.2",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "mustache": "^4.2.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.3",
    "sinon-chai": "^4.0.1",
    "typescript": "~5.9.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes"
  },
  "bugs": {
    "url": "https://github.com/nobl/ioBroker.tesla-wallconnector3/issues"
  },
  "readmeFilename": "README.md"
}
